DATABASE_URL=postgresql://user:password@host:5432/dbname
PORT=3000

# Password for the hidden admin console (/admin-251029 or /pages/admin-251029.html).
# Defaults to 251029 if unset — CHANGE THIS before deploying anywhere public.
# A 6-digit numeric code is weak against brute-forcing even with rate limiting;
# prefer something longer (letters+digits) for a real deployment.
ADMIN_CODE=251029
